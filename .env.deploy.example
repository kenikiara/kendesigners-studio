# Copy this file to ".env.deploy" and fill in your cPanel FTP details.
# .env.deploy is git-ignored and never uploaded or committed.
# Find these in cPanel under "FTP Accounts".

FTP_HOST=ftp.yourdomain.com
FTP_USER=your-ftp-username
FTP_PASSWORD=your-ftp-password

# Usually 21. Leave as-is unless your host says otherwise.
FTP_PORT=21

# true = FTPS (secure). Set to false only if your host does not support it.
FTP_SECURE=true

# The folder your site is served from. For a root domain this is public_html.
# For a subdomain or subfolder, use that folder's path instead.
FTP_REMOTE_DIR=public_html
